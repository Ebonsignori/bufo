#!/usr/bin/env bash
# bufo - iTerm2 tadpole manager for multi-repo development
set -e

BUFO_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$BUFO_SOURCE" ]; do
  BUFO_DIR="$(cd "$(dirname "$BUFO_SOURCE")" && pwd)"
  BUFO_SOURCE="$(readlink "$BUFO_SOURCE")"
  [[ "$BUFO_SOURCE" != /* ]] && BUFO_SOURCE="$BUFO_DIR/$BUFO_SOURCE"
done
BUFO_DIR="$(cd "$(dirname "$BUFO_SOURCE")" && pwd)"
LIB="$BUFO_DIR/lib"

source "$LIB/common.sh"
source "$LIB/config.sh"
source "$LIB/prompts.sh"
source "$LIB/projects.sh"
source "$LIB/iterm.sh"
source "$LIB/state.sh"
source "$LIB/ports.sh"
source "$LIB/companions.sh"
source "$LIB/worktree.sh"
source "$LIB/tadpole.sh"
source "$LIB/wip.sh"
source "$LIB/session.sh"
source "$LIB/review.sh"
source "$LIB/pr.sh"
source "$LIB/merge.sh"
source "$LIB/ticket.sh"
source "$LIB/doctor.sh"
source "$LIB/init.sh"
source "$LIB/setup.sh"
source "$LIB/web.sh"
source "$LIB/raycast.sh"
source "$LIB/infobar.sh"
source "$LIB/help.sh"

main() {
  # Allow --version and help without deps
  case "${1:-}" in
    "--version"|"-v"|"help"|"-h"|"--help"|"cheat") ;;
    *) check_deps ;;
  esac

  # @alias stripping: bufo @pf tp 1 → resolve project, then route "tp 1"
  PROJECT_ALIAS=""
  if [[ "${1:-}" == @* ]]; then
    resolve_project "$1"
    shift
  fi

  # Resolve user-configured command aliases (before project + command dispatch)
  if resolved=$(resolve_command_aliases "${1:-}"); then
    shift
    read -r -a resolved_parts <<<"$resolved"
    set -- "${resolved_parts[@]}" "$@"
  fi

  # For project-aware commands, resolve project (cwd-first, then default)
  case "${1:-}" in
    ""|"tp"|"tadpole"|"restart"|"reset"|"refresh"|"continue"|"resume"|"cleanup"|"clean"|"destroy"|"rm"|"remove"|"spawn"|"create"|"wip"|"save"|"config"|"doctor"|"ports"|"shared"|"session"|"review"|"court"|"chorus"|"pr"|"merge"|"ticket"|"tkt"|"lock"|"unlock"|"unlock-all"|"kill"|"switch"|"sw"|"main"|"companions")
      if [ -z "$PROJECT_ALIAS" ]; then
        if is_legacy_config; then
          check_legacy_migration
        fi
        resolve_project_from_cwd 2>/dev/null || resolve_project ""
      fi
      ;;
  esac

  case "${1:-}" in
    "setup-terminal"|"setup"|"init"|"help"|"-h"|"--help"|"cheat"|"--version"|"-v"|"web"|"raycast"|"install"|"_"*) ;;
    *) check_setup_reminder ;;
  esac

  case "${1:-}" in
    "")
      list_tadpoles
      ;;
    "tp"|"tadpole")
      load_config
      # Quick-exit arg validation before requiring a complete config
      _tp_num="${2:-}"
      _tp_subcmd="${3:-}"
      if [[ "$_tp_num" =~ ^[0-9]+$ ]]; then
        case "$_tp_subcmd" in
          "ticket"|"tkt")
            _tp_ticket_id="${4:-}"
            if [ -z "$_tp_ticket_id" ]; then
              error "Ticket identifier required: bufo tp $_tp_num ticket <identifier>"
              exit 1
            fi
            _tp_parsed_id=$(parse_ticket_identifier "$_tp_ticket_id")
            if ! [[ "$_tp_parsed_id" =~ ^#?[A-Za-z0-9_-]+$ ]]; then
              error "Invalid ticket identifier: $_tp_parsed_id"
              echo "Identifiers must be alphanumeric (dashes and underscores allowed)"
              exit 1
            fi
            ;;
          "pr")
            _tp_pr_id="${4:-}"
            if [ -z "$_tp_pr_id" ]; then
              error "PR identifier required: bufo tp $_tp_num pr <PR>"
              exit 1
            fi
            ;;
        esac
      fi
      validate_config
      handle_tp_command "${@:2}"
      ;;
    "init")
      show_init "${@:2}"
      ;;
    "config")
      if [ "${2:-}" = "scan" ]; then
        config_scan
      else
        show_config
      fi
      ;;
    "doctor")
      if [ "${2:-}" = "--fix" ] || [ "${2:-}" = "fix" ]; then
        local force=false
        [ "${3:-}" = "--force" ] && force=true
        doctor_fix "$force"
      else
        show_doctor
      fi
      ;;
    "install")
      BUFO_VERSION="$VERSION" bash "$BUFO_DIR/install.sh" "${@:2}"
      ;;
    "web")
      handle_web_command "${@:2}"
      ;;
    "raycast")
      handle_raycast_command "${@:2}"
      ;;
    "cheat"|"help"|"-h"|"--help")
      if [ "${1:-}" = "cheat" ]; then
        show_cheat
      else
        show_help
      fi
      ;;
    "ports")
      show_ports
      ;;
    "shared")
      show_shared
      ;;
    "session"|"sessions")
      handle_session_command "${@:2}"
      ;;
    "review")
      load_config 2>/dev/null || true
      handle_review_command "${@:2}"
      ;;
    "court"|"chorus")
      load_config 2>/dev/null || true
      handle_chorus_command "${@:2}"
      ;;
    "pr")
      # Show usage before requiring a config file
      if [ -z "${2:-}" ]; then
        error "PR identifier required"
        echo ""
        echo "Usage: bufo pr <PR>"
        echo "       bufo tp <N> pr <PR>"
        echo ""
        echo "Formats:"
        echo "  bufo pr 123"
        echo "  bufo pr repo#456"
        echo "  bufo pr https://github.com/owner/repo/pull/789"
        exit 1
      fi
      load_config
      validate_config
      handle_pr_command "${@:2}"
      ;;
    "merge")
      load_config
      validate_config
      handle_merge_command "${@:2}"
      ;;
    "main")
      if [ -z "$PROJECT_ALIAS" ]; then
        error "The main command requires an explicit project alias"
        echo ""
        echo "Usage: bufo @<alias> main"
        exit 1
      fi
      load_config
      validate_config
      open_main_tadpole
      ;;
    "ticket"|"tkt")
      # Validate args before requiring a config file
      _ticket_id="${2:-}"
      if [ -z "$_ticket_id" ]; then
        error "Ticket identifier required"
        echo ""
        echo "Usage: bufo ticket <identifier>"
        echo "       bufo tp <N> ticket <identifier>"
        echo ""
        echo "Examples:"
        echo "  bufo ticket ENG-123"
        echo "  bufo ticket https://linear.app/team/issue/ENG-123/title"
        echo "  bufo ticket https://github.com/owner/repo/issues/42"
        echo "  bufo tp 3 ticket ENG-123"
        exit 1
      fi
      _parsed_id=$(parse_ticket_identifier "$_ticket_id")
      if ! [[ "$_parsed_id" =~ ^#?[A-Za-z0-9_-]+$ ]]; then
        error "Invalid ticket identifier: $_parsed_id"
        echo "Identifiers must be alphanumeric (dashes and underscores allowed)"
        exit 1
      fi
      load_config
      validate_config
      handle_ticket_command "${@:2}"
      ;;
    "projects"|"project"|"proj")
      show_projects "${@:2}"
      ;;
    "default")
      set_default_project "${2:-}"
      ;;
    "alias"|"aliases")
      handle_alias_command "${@:2}"
      ;;
    "spawn"|"create")
      load_config
      validate_config
      # Warn if cwd resolved a different project than the default
      if [ -n "$PROJECT_ALIAS" ] && [ -f "$GLOBAL_CONFIG" ]; then
        _spawn_default=$(yq -r '.default_project // ""' "$GLOBAL_CONFIG" 2>/dev/null)
        [ "$_spawn_default" = "null" ] && _spawn_default=""
        if [ -n "$_spawn_default" ] && [ "$_spawn_default" != "$PROJECT_ALIAS" ]; then
          warn "Matched @$PROJECT_ALIAS from current directory (default is @$_spawn_default)"
          echo -e "${YELLOW}  Run 'bufo @$_spawn_default spawn' to target your default project.${NC}"
          echo ""
        fi
      fi
      create_new_tadpole "$@"
      ;;
    "restart"|"reset"|"refresh")
      load_config
      validate_config
      num=$(detect_tadpole)
      if [ -z "$num" ]; then
        error "Cannot detect tadpole. Run from a tadpole dir or use: bufo tp <N> restart"
        exit 1
      fi
      restart_tadpole "$num"
      ;;
    "continue"|"resume")
      load_config
      validate_config
      num=$(detect_tadpole)
      if [ -z "$num" ]; then
        error "Cannot detect tadpole. Run from a tadpole dir or use: bufo tp <N> continue"
        exit 1
      fi
      continue_tadpole "$num"
      ;;
    "cleanup"|"clean")
      load_config
      validate_config
      num=$(detect_tadpole)
      if [ -z "$num" ]; then
        error "Cannot detect tadpole. Run from a tadpole dir or use: bufo tp <N> cleanup"
        exit 1
      fi
      cleanup_tadpole "$num"
      ;;
    "switch"|"sw")
      load_config
      validate_config
      switch_tadpole "${2:-}"
      ;;
    "lock")
      load_config
      num=$(detect_tadpole)
      if [ -z "$num" ]; then
        error "Cannot detect tadpole. Run from a tadpole dir or use: bufo tp <N> lock"
        exit 1
      fi
      validate_config
      lock_tadpole "$num"
      ;;
    "unlock")
      load_config
      num=$(detect_tadpole)
      if [ -z "$num" ]; then
        error "Cannot detect tadpole. Run from a tadpole dir or use: bufo tp <N> unlock"
        exit 1
      fi
      validate_config
      unlock_tadpole "$num"
      ;;
    "unlock-all")
      load_config
      validate_config
      unlock_all_tadpoles
      ;;
    "kill")
      load_config
      validate_config
      num=$(detect_tadpole)
      if [ -z "$num" ]; then
        error "Cannot detect tadpole. Run from a tadpole dir or use: bufo tp <N> kill"
        exit 1
      fi
      local tp_dir="$TADPOLE_BASE/$TADPOLE_PREFIX-$num"
      echo -e "${YELLOW}Killing ports for tadpole $num...${NC}"
      kill_workspace_ports "$tp_dir"
      ;;
    "save")
      load_config
      validate_config
      num=$(detect_tadpole)
      if [ -z "$num" ]; then
        error "Not in a tadpole directory. Run from inside a tadpole."
        exit 1
      fi
      local do_restart="false"
      local custom_name=""
      shift
      while [ $# -gt 0 ]; do
        case "$1" in
          --restart|-r)
            do_restart="true"
            shift
            ;;
          *)
            custom_name="$1"
            shift
            ;;
        esac
      done
      wip_save "$num" "$do_restart" "$custom_name"
      ;;
    "destroy"|"rm"|"remove")
      load_config
      validate_config
      if [ -n "${2:-}" ] && [[ "${2:-}" =~ ^[0-9]+$ ]]; then
        destroy_tadpole "$2" "${3:-}"
      else
        num=$(detect_tadpole)
        if [ -z "$num" ]; then
          error "Specify tadpole: bufo destroy <N>"
          exit 1
        fi
        destroy_tadpole "$num" "${2:-}"
      fi
      ;;
    "wip")
      load_config
      validate_config
      num=$(detect_tadpole)

      case "${2:-}" in
        "save")
          if [ -z "$num" ]; then
            error "Not in a tadpole directory. Use: bufo tp <N> wip save"
            exit 1
          fi
          local do_restart="false"
          local custom_name=""
          shift 2
          while [ $# -gt 0 ]; do
            case "$1" in
              --restart|-r)
                do_restart="true"
                shift
                ;;
              *)
                custom_name="$1"
                shift
                ;;
            esac
          done
          wip_save "$num" "$do_restart" "$custom_name"
          ;;
        "ls"|"list")
          local dir_ws=$(detect_tadpole_from_dir)
          if [ "${3:-}" = "--ws" ] && [ -n "$num" ]; then
            wip_list "$num"
          elif [ -n "$dir_ws" ] && [ "${3:-}" != "--all" ] && [ "${3:-}" != "-a" ]; then
            wip_list "$dir_ws"
            echo -e "${GRAY}Use 'bufo wip ls --all' to see all tadpoles${NC}"
          else
            wip_list_global
          fi
          ;;
        "restore")
          local target_ws=""
          local index=""
          local open_after="false"
          shift 2

          while [ $# -gt 0 ]; do
            case "$1" in
              --to)
                target_ws="${2:-}"
                shift 2
                ;;
              --open|-o)
                open_after="true"
                shift
                ;;
              *)
                if [ -z "$index" ] && [[ "$1" =~ ^[0-9]+$ ]]; then
                  index="$1"
                fi
                shift
                ;;
            esac
          done

          if [ -z "$index" ]; then
            wip_restore_global "$target_ws" "$open_after"
          else
            wip_restore_by_index "$index" "$target_ws" "$open_after"
          fi
          ;;
        "--continue"|"-c")
          if [ -z "$num" ]; then
            error "Not in a tadpole directory. Use: bufo wip restore"
            exit 1
          fi
          local open_flag="false"
          if [ "${3:-}" = "--open" ] || [ "${3:-}" = "-o" ]; then
            open_flag="true"
          fi
          wip_continue "$num" "$open_flag"
          ;;
        "--resume"|"-r"|"resume")
          if [ -z "$num" ]; then
            wip_restore_global
          else
            wip_resume "$num"
          fi
          ;;
        "delete"|"rm")
          if [ -z "$num" ]; then
            error "Not in a tadpole directory. Use: bufo tp <N> wip delete <name>"
            exit 1
          fi
          wip_delete "$num" "${3:-}"
          ;;
        *)
          echo -e "${CYAN}WIP Commands:${NC}"
          echo ""
          if [ -n "$num" ]; then
            echo -e "  ${BOLD}In tadpole $num:${NC}"
            echo "    bufo wip save [--restart]  Save current changes"
            echo "    bufo wip ls                List WIPs for this tadpole"
            echo "    bufo wip --continue        Restore most recent WIP"
            echo "    bufo wip --resume          Interactive WIP selection"
            echo "    bufo wip delete <name>     Delete a WIP state"
            echo ""
          fi
          echo -e "  ${BOLD}Global commands:${NC}"
          echo "    bufo wip ls                List all WIPs (global view)"
          echo "    bufo wip restore           Interactive restore from all WIPs"
          echo "    bufo wip restore <N>       Restore WIP #N to its original tadpole"
          echo "    bufo wip restore <N> --to <ws>  Restore WIP #N to tadpole <ws>"
          echo "    bufo wip restore <N> --open     Restore and open tadpole"
          echo ""
          echo "  Restores: branch, commits, staged/unstaged changes, submodules"
          ;;
      esac
      ;;
    "_infobar-render")
      # Internal command: render info bar for a tadpole directory
      # Usage: bufo _infobar-render <tadpole-dir> [pull-label]
      local render_dir="${2:-}"
      local pull_label="${3:-}"
      if [ -z "$render_dir" ]; then
        error "Usage: bufo _infobar-render <tadpole-dir>"
        exit 1
      fi
      # Load config so tab title updates work when PR is discovered
      cd "$render_dir"
      resolve_project_from_cwd 2>/dev/null || resolve_project "" 2>/dev/null || true
      load_config 2>/dev/null || true
      # sync and render must not fail under set -e (called from info bar loop)
      sync_workspace_pr "$render_dir" || true
      render_infobar "$render_dir" || true
      render_infobar_actions "$render_dir" "$pull_label"
      ;;
    "_quit-tadpole")
      # Internal command: gracefully quit a tadpole (save WIP, close panes)
      # Called from the info bar script
      local quit_dir="${2:-}"
      if [ -z "$quit_dir" ]; then
        error "Usage: bufo _quit-tadpole <tadpole-dir>"
        exit 1
      fi
      cd "$quit_dir"
      resolve_project_from_cwd 2>/dev/null || resolve_project ""
      load_config
      validate_config
      quit_tadpole "$quit_dir"
      ;;
    "_kill-ports")
      # Internal command: kill processes on managed ports for a tadpole
      # Called from the info bar script
      local kill_dir="${2:-}"
      if [ -z "$kill_dir" ]; then
        error "Usage: bufo _kill-ports <tadpole-dir>"
        exit 1
      fi
      cd "$kill_dir"
      resolve_project_from_cwd 2>/dev/null || resolve_project ""
      load_config
      validate_config
      kill_workspace_ports "$kill_dir"
      ;;
    "_cleanup-tadpole")
      # Internal command: cleanup tadpole (reset git, unlock, close panes)
      # Called from the info bar script
      local cleanup_dir="${2:-}"
      if [ -z "$cleanup_dir" ]; then
        error "Usage: bufo _cleanup-tadpole <tadpole-dir>"
        exit 1
      fi
      cd "$cleanup_dir"
      resolve_project_from_cwd 2>/dev/null || resolve_project ""
      load_config
      validate_config
      cleanup_tadpole_infobar "$cleanup_dir"
      ;;
    "_infobar-render-main")
      # Internal command: render info bar for main tadpole
      local render_dir="${2:-}"
      local pull_label="${3:-}"
      if [ -z "$render_dir" ]; then
        error "Usage: bufo _infobar-render-main <dir>"
        exit 1
      fi
      cd "$render_dir"
      resolve_project_from_cwd 2>/dev/null || resolve_project "" 2>/dev/null || true
      load_config 2>/dev/null || true
      render_main_infobar "$render_dir" || true
      render_main_infobar_actions "$render_dir" "$pull_label"
      ;;
    "_quit-main")
      # Internal command: quit main tadpole (close tab, no WIP save)
      local quit_dir="${2:-}"
      if [ -z "$quit_dir" ]; then
        error "Usage: bufo _quit-main <dir>"
        exit 1
      fi
      cd "$quit_dir"
      resolve_project_from_cwd 2>/dev/null || resolve_project ""
      load_config
      validate_config
      quit_main_tadpole "$quit_dir"
      ;;
    "_merge-main")
      # Internal command: run merge from main tadpole info bar
      local merge_dir="${2:-}"
      if [ -z "$merge_dir" ]; then
        error "Usage: bufo _merge-main <dir>"
        exit 1
      fi
      cd "$merge_dir"
      resolve_project_from_cwd 2>/dev/null || resolve_project ""
      load_config
      validate_config
      handle_merge_command
      ;;
    "companions")
      load_config
      validate_config
      case "${2:-}" in
        "sync")
          sync_all_companions "${@:3}"
          ;;
        "fetch")
          fetch_companions
          ;;
        "add")
          error "Interactive 'companions add' is not yet implemented."
          echo "Edit your project config directly: $CONFIG_FILE"
          echo ""
          echo "Add a block like:"
          echo "  companions:"
          echo "    repos:"
          echo "      - name: my-shared-lib"
          echo "        remote: git@github.com:org/my-shared-lib.git"
          exit 1
          ;;
        ""|"status"|"show")
          show_companions
          ;;
        *)
          error "Unknown companions sub-command: ${2:-}"
          echo ""
          echo "Usage:"
          echo "  bufo companions            Show companion status"
          echo "  bufo companions sync       Retroactively symlink into all tadpoles"
          echo "  bufo companions sync --replace  Replace existing directories with symlinks"
          echo "  bufo companions fetch      Run git fetch in each canonical clone"
          exit 1
          ;;
      esac
      ;;
    "update"|"upgrade")
      echo -e "${CYAN}Updating bufo...${NC}"
      local install_dir
      install_dir=$(dirname "$(realpath "$0")")
      local tmp_file
      tmp_file=$(mktemp /tmp/bufo-update.XXXXXX)
      local tmp_hash
      tmp_hash=$(mktemp /tmp/bufo-update-hash.XXXXXX)

      # Determine which sha256 tool is available (Linux: sha256sum, macOS: shasum)
      local sha_cmd
      if command_exists sha256sum; then
        sha_cmd="sha256sum"
      elif command_exists shasum; then
        sha_cmd="shasum -a 256"
      else
        error "sha256sum or shasum is required for update verification but was not found"
        rm -f "$tmp_file" "$tmp_hash"
        exit 1
      fi

      # Determine latest released version via GitHub API
      local latest_version
      latest_version=$(curl -fsSL \
        "https://api.github.com/repos/Ebonsignori/bufo/releases/latest" \
        2>/dev/null | grep '"tag_name"' | head -1 | cut -d'"' -f4)

      if [ -z "$latest_version" ]; then
        error "Failed to determine latest version"
        rm -f "$tmp_file" "$tmp_hash"
        exit 1
      fi

      local current_version="$VERSION"

      if [ "$latest_version" = "v$current_version" ]; then
        echo -e "${GREEN}Already up to date (v$current_version)${NC}"
        rm -f "$tmp_file" "$tmp_hash"
        return
      fi

      local base_url="https://github.com/Ebonsignori/bufo/releases/download/${latest_version}"

      # Download script and checksum sidecar from the pinned release
      if ! curl -fsSL "${base_url}/bufo"        -o "$tmp_file"  2>/dev/null; then
        error "Failed to download update"
        rm -f "$tmp_file" "$tmp_hash"
        exit 1
      fi
      if ! curl -fsSL "${base_url}/bufo.sha256" -o "$tmp_hash"  2>/dev/null; then
        error "Failed to download checksum"
        rm -f "$tmp_file" "$tmp_hash"
        exit 1
      fi

      # Verify integrity before touching the installed copy
      local expected_hash
      expected_hash=$(awk '{print $1}' "$tmp_hash")
      local actual_hash
      actual_hash=$($sha_cmd "$tmp_file" | awk '{print $1}')

      if [ "$actual_hash" != "$expected_hash" ]; then
        error "Integrity check failed — update aborted"
        error "  expected: $expected_hash"
        error "  got:      $actual_hash"
        rm -f "$tmp_file" "$tmp_hash"
        exit 1
      fi

      chmod +x "$tmp_file"
      mv "$tmp_file" "$install_dir/bufo"
      rm -f "$tmp_hash"

      # Download and update lib directory alongside the main script
      local tmp_lib tmp_lib_hash
      tmp_lib=$(mktemp /tmp/bufo-update-lib.XXXXXX)
      tmp_lib_hash=$(mktemp /tmp/bufo-update-lib-hash.XXXXXX)

      if ! curl -fsSL "${base_url}/bufo-lib.tar.gz" -o "$tmp_lib" 2>/dev/null; then
        error "Failed to download lib update"
        rm -f "$tmp_lib" "$tmp_lib_hash"
        exit 1
      fi
      if ! curl -fsSL "${base_url}/bufo-lib.tar.gz.sha256" -o "$tmp_lib_hash" 2>/dev/null; then
        error "Failed to download lib checksum"
        rm -f "$tmp_lib" "$tmp_lib_hash"
        exit 1
      fi

      local expected_lib_hash actual_lib_hash
      expected_lib_hash=$(awk '{print $1}' "$tmp_lib_hash")
      actual_lib_hash=$($sha_cmd "$tmp_lib" | awk '{print $1}')

      if [ "$actual_lib_hash" != "$expected_lib_hash" ]; then
        error "Lib integrity check failed — update aborted"
        error "  expected: $expected_lib_hash"
        error "  got:      $actual_lib_hash"
        rm -f "$tmp_lib" "$tmp_lib_hash"
        exit 1
      fi

      mkdir -p "$install_dir/lib"
      tar -xzf "$tmp_lib" -C "$install_dir" lib/
      rm -f "$tmp_lib" "$tmp_lib_hash"

      # Download and update daemon dist
      local tmp_daemon tmp_daemon_hash
      tmp_daemon=$(mktemp /tmp/bufo-update-daemon.XXXXXX)
      tmp_daemon_hash=$(mktemp /tmp/bufo-update-daemon-hash.XXXXXX)

      if ! curl -fsSL "${base_url}/bufo-daemon.tar.gz" -o "$tmp_daemon" 2>/dev/null; then
        error "Failed to download daemon update"
        rm -f "$tmp_daemon" "$tmp_daemon_hash"
        exit 1
      fi
      if ! curl -fsSL "${base_url}/bufo-daemon.tar.gz.sha256" -o "$tmp_daemon_hash" 2>/dev/null; then
        error "Failed to download daemon checksum"
        rm -f "$tmp_daemon" "$tmp_daemon_hash"
        exit 1
      fi

      local expected_daemon_hash actual_daemon_hash
      expected_daemon_hash=$(awk '{print $1}' "$tmp_daemon_hash")
      actual_daemon_hash=$($sha_cmd "$tmp_daemon" | awk '{print $1}')

      if [ "$actual_daemon_hash" != "$expected_daemon_hash" ]; then
        error "Daemon integrity check failed — update aborted"
        error "  expected: $expected_daemon_hash"
        error "  got:      $actual_daemon_hash"
        rm -f "$tmp_daemon" "$tmp_daemon_hash"
        exit 1
      fi

      mkdir -p "$install_dir/daemon"
      tar -xzf "$tmp_daemon" -C "$install_dir/daemon"
      rm -f "$tmp_daemon" "$tmp_daemon_hash"

      # Install/update runtime dependencies
      if command_exists npm; then
        npm install --omit=dev --legacy-peer-deps --prefix "$install_dir/daemon" 2>&1 || \
          echo -e "${YELLOW}Warning: npm install for daemon failed${NC}"
      fi

      echo -e "${GREEN}Updated: v$current_version → ${latest_version#v}${NC}"

      # Restart daemon if it's already running
      if launchctl list 2>/dev/null | grep -q "com.bufo.daemon"; then
        echo -e "${CYAN}Restarting daemon...${NC}"
        "$install_dir/bufo" web restart 2>/dev/null || true
      fi
      ;;
    "--version"|"-v")
      echo ' ◎ , ◎'
      echo '（ -──）'
      echo '/(    )\'
      echo "bufo v$VERSION"
      ;;
    *)
      # Auto-detect URL type: route GitHub PR URLs and Linear ticket URLs
      if [[ "$1" =~ ^https://github\.com/[^/]+/[^/]+/pull/[0-9]+ ]]; then
        if [ -z "$PROJECT_ALIAS" ]; then
          if is_legacy_config; then
            check_legacy_migration
          fi
          if ! resolve_project_from_github_url "$1" 2>/dev/null; then
            local url_repo
            url_repo=$(echo "$1" | sed -n 's|.*github\.com[:/]\([^/]*/[^/]*\).*|\1|p')
            error "No project configured for ${url_repo:-this repository}"
            echo "Run 'bufo init' from the repo to configure it as a project first."
            exit 1
          fi
        fi
        load_config
        validate_config
        handle_pr_command "$1"
      elif [[ "$1" =~ ^https://github\.com/[^/]+/[^/]+/issues/[0-9]+ ]]; then
        if [ -z "$PROJECT_ALIAS" ]; then
          if is_legacy_config; then
            check_legacy_migration
          fi
          # Try configured ticket.github_repo first, then fall back to interactive
          if ! resolve_project_from_ticket_url "$1" 2>/dev/null; then
            select_project_interactive "for issue: $1"
          fi
        fi
        load_config
        validate_config
        handle_ticket_command "$1"
      elif [[ "$1" =~ ^https://linear\.app/ ]]; then
        if [ -z "$PROJECT_ALIAS" ]; then
          if is_legacy_config; then
            check_legacy_migration
          fi
          # Try configured ticket.linear_team first, then CWD, then default
          resolve_project_from_ticket_url "$1" 2>/dev/null \
            || resolve_project_from_cwd 2>/dev/null \
            || resolve_project ""
        fi
        load_config
        validate_config
        handle_ticket_command "$1"
      # Backwards compatibility: bufo <N> -> bufo tp <N>
      elif [[ "$1" =~ ^[0-9]+$ ]]; then
        if [ -z "$PROJECT_ALIAS" ]; then
          if is_legacy_config; then
            check_legacy_migration
          fi
          resolve_project_from_cwd 2>/dev/null || resolve_project ""
        fi
        load_config
        validate_config
        handle_tp_command "$@"
      else
        error "Unknown command: $1"
        echo ""
        echo "Common commands:"
        echo "  bufo tp <N>          Open tadpole N"
        echo "  bufo spawn           Create new tadpole"
        echo "  bufo restart         Restart current tadpole"
        echo "  bufo pr <PR>         Open tadpole for a GitHub PR"
        echo "  bufo ticket <ID>     Open tadpole for a ticket"
        echo "  bufo merge           Merge tadpole branches into main"
        echo "  bufo @<alias> main   Open main repo with tadpole layout"
        echo "  bufo unlock-all      Unlock all non-active tadpoles"
        echo "  bufo switch          Switch between active tadpoles"
        echo "  bufo doctor          Diagnose issues (--fix to repair)"
        echo "  bufo projects        List registered projects"
        echo "  bufo wip save/ls     Save or list work-in-progress"
        echo ""
        echo "  bufo help            Full command reference"
        echo "  bufo cheat           Cheat sheet"
        exit 1
      fi
      ;;
  esac
}

main "$@"
