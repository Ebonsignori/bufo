{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "bufo",
  "title": "Bufo",
  "description": "Manage bufo tadpoles from Raycast",
  "icon": "command-icon.png",
  "author": "ebonsignori",
  "categories": [
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "list-tadpoles",
      "title": "List Tadpoles",
      "description": "List all bufo tadpoles across projects",
      "mode": "view"
    },
    {
      "name": "new-tadpole",
      "title": "New Tadpole",
      "description": "Create a new bufo tadpole",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.11",
    "@raycast/utils": "^2.2.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "22.x",
    "@types/react": "18.x",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint"
  }
}
