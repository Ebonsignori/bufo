{
  "name": "bufo-daemon",
  "version": "1.0.0",
  "description": "Mobile web daemon for bufo — serves workspace list and bridges to iTerm2",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && npm run build:bundle && npm run build:css",
    "build:bundle": "esbuild src/bundle.ts --bundle --outfile=public/xterm-bundle.js --platform=browser --format=iife",
    "build:css": "cp node_modules/@xterm/xterm/css/xterm.css public/xterm.css",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts"
  },
  "dependencies": {
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "js-yaml": "^4.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
